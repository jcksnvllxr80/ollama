    {
      "id": "step1_text",
      "type": "text",
      "x": 100,
      "y": 510,
      "width": 470,
      "height": 100,
      "text": "# Linux / macOS (WSL for Windows)\ncurl -fsSL https://ollama.com/install.sh | sh\n\n# Windows: download from ollama.com\n# macOS: also available via `brew install ollama`",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "step1"
      ],
      "boundElements": [],
      "seed": 102,
