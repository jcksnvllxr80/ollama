    {
      "id": "step4_text",
      "type": "text",
      "x": 100,
      "y": 1200,
      "width": 560,
      "height": 200,
      "text": "# Add to ~/.bashrc or ~/.zshrc for persistence:\n\nexport ANTHROPIC_AUTH_TOKEN=\"ollama\"\nexport ANTHROPIC_API_KEY=\"\"\nexport ANTHROPIC_BASE_URL=\"http://localhost:11434\"\n\n# Optional: disable telemetry/phone-home\nexport CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1\n\n# Then reload:\nsource ~/.bashrc   # or source ~/.zshrc",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "step4"
      ],
