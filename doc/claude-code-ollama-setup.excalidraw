    {
      "id": "step4_text",
      "type": "text",
      "x": 100,
      "y": 1200,
      "width": 560,
      "height": 200,
      "text": "# PowerShell — set permanently:\n[Environment]::SetEnvironmentVariable(\n  \"ANTHROPIC_API_KEY\", \"ollama\", \"User\")\n[Environment]::SetEnvironmentVariable(\n  \"ANTHROPIC_BASE_URL\",\n  \"http://localhost:11434\", \"User\")\n\n# Then launch Claude Code:\nclaude --model minimax-m2.5:cloud",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
