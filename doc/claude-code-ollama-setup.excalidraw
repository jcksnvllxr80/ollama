      "isDeleted": false,
      "roundness": null,
      "updated": 1772935823227,
      "link": null,
      "locked": false,
      "index": "b0J",
      "strokeStyle": "solid",
      "frameId": null,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "# Linux / macOS (WSL for Windows)\ncurl -fsSL https://ollama.com/install.sh | sh\n\n# Windows: download from ollama.com\n# macOS: also available via `brew install ollama`",
      "autoResize": true,
      "lineHeight": 1.4285714285714286
    },
    {
      "id": "step1_note",
      "type": "text",
      "x": 620,
      "y": 500,
      "width": 500,
      "height": 120,
      "text": "💡 Ollama auto-detects your GPU:\n   • NVIDIA: uses CUDA (needs drivers)\n   • AMD: uses ROCm\n   • Apple Silicon: uses Metal\n   • No GPU? Falls back to CPU (slower)\n\n   Verify: ollama -v",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "groupIds": [
        "step1"
      ],
      "boundElements": [],
      "seed": 103,
      "version": 3,
      "versionNonce": 1681330282,
      "isDeleted": false,
      "roundness": null,
      "updated": 1772935823227,
      "link": null,
      "locked": false,
      "index": "b0K",
      "strokeStyle": "solid",
      "frameId": null,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "💡 Ollama auto-detects your GPU:\n   • NVIDIA: uses CUDA (needs drivers)\n   • AMD: uses ROCm\n   • Apple Silicon: uses Metal\n   • No GPU? Falls back to CPU (slower)\n\n   Verify: ollama -v",
      "autoResize": true,
      "lineHeight": 1.2244897959183674
    },
